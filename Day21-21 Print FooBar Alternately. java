class FooBar {
private:
    int n;
    mutex mtx;
    condition_variable cv;
    bool fooTurn;

public:
    FooBar(int n) {
        this->n = n;
        fooTurn = true;
    }

    void foo(function<void()> printFoo) {
        for (int i = 0; i < n; i++) {
            unique_lock<mutex> lock(mtx);
            cv.wait(lock, [this] { return fooTurn; });

            printFoo();
            fooTurn = false;

            cv.notify_all();
        }
    }

    void bar(function<void()> printBar) {
        for (int i = 0; i < n; i++) {
            unique_lock<mutex> lock(mtx);
            cv.wait(lock, [this] { return !fooTurn; });

            printBar();
            fooTurn = true;

            cv.notify_all();
        }
    }
}
